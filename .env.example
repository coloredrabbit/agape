# 네이버 개발자센터(https://developers.naver.com/apps)에서 앱 등록 후 발급
# 사용 API: 데이터랩(검색어트렌드), 데이터랩(쇼핑인사이트)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Cloud Console에서 YouTube Data API v3 활성화 후 API 키 발급
YOUTUBE_API_KEY=

# --- 리포트 전송 ---
# 전송 대상(어떤 채널로, 누구에게)은 channels.yaml에서 정의한다. 여기엔 비밀정보만 둔다.

# (선택) Slack Incoming Webhook URL — channels.yaml의 slack 채널에서 webhook_env로 참조
SLACK_WEBHOOK_URL=

# (선택) 이메일 발송용 SMTP — channels.yaml에 email 채널이 있을 때만 필요
# 예: Gmail은 host=smtp.gmail.com, port=587, user=주소, password=앱 비밀번호(2단계 인증 후 발급)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=            # 보내는 사람 주소 (생략 시 SMTP_USER 사용)
SMTP_STARTTLS=true    # 465 포트(SSL)면 자동으로 SSL 사용, 그 외엔 STARTTLS

# --- Pinterest ---
# 한국(KR) 트렌드는 인증 없는 크롤러가 담당하므로 아래 값 없이도 핀터레스트 수집은 동작한다.

# (선택) 공식 Trends API — US/글로벌 선행 신호용. 한국은 공식 API 미지원(US/EU/중남미만).
# developers.pinterest.com에서 앱 생성 후 App ID/Secret 발급. client_credentials 방식이라
# OAuth 리다이렉트 불필요. Trends 데이터 접근은 Pinterest 파트너 승인이 필요할 수 있음(미승인 시 403).
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# 공식 API 조회 지역/관심사 (기본 US / beauty). 지원 지역: US, CA, DE, FR, ES, IT, GB+IE 등 — KR 없음
PINTEREST_OFFICIAL_REGION=US
PINTEREST_OFFICIAL_INTEREST=beauty

# (선택) KR 크롤러 인증 — 없어도 동작. 차단이 잦거나 로그인 세션이 필요할 때만 설정.
# PINTEREST_COOKIE: 브라우저에서 복사한 Cookie 헤더 전체. PINTEREST_CRAWLER_UA: 요청 User-Agent 덮어쓰기.
PINTEREST_COOKIE=
PINTEREST_CRAWLER_UA=
